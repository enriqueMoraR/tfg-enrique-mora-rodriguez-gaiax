{
  "info": {
    "_postman_id": "b78e3b8f-7b60-4f4d-8f9f-4d4f7f0d3d31",
    "name": "Gaia-X Health E2E",
    "description": "Colección para probar el flujo completo: ingesta FHIR -> PostgreSQL -> dashboard.\n\nLa petición principal genera 20 pacientes, 20 dispositivos y 20 observaciones de forma automática mediante un Bundle FHIR.\n\nIncluye healthchecks de provider, trust, consumer y una comprobación básica del dashboard.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Ingesta FHIR Bundle",
      "description": "Genera 20 pacientes y sus observaciones de presión arterial y los persiste en PostgreSQL.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function pad(value) {",
              "  return String(value).padStart(3, '0');",
              "}",
              "",
              "function buildTimestamp(base, minutesOffset) {",
              "  return new Date(base.getTime() + minutesOffset * 60 * 1000).toISOString();",
              "}",
              "",
              "function buildPatient(index, timestamp) {",
              "  const suffix = pad(index);",
              "  return {",
              "    resourceType: 'Patient',",
              "    id: `patient-gx-${suffix}`,",
              "    meta: {",
              "      versionId: '1',",
              "      lastUpdated: timestamp",
              "    },",
              "    name: [",
              "      {",
              "        text: `Paciente Gaia ${suffix}`",
              "      }",
              "    ],",
              "    gender: index % 2 === 0 ? 'female' : 'male',",
              "    birthDate: `19${70 + (index % 25)}-0${(index % 9) + 1}-1${index % 9}`",
              "  };",
              "}",
              "",
              "function buildDevice(index, timestamp) {",
              "  const suffix = pad(index);",
              "  return {",
              "    resourceType: 'Device',",
              "    id: `tensiometer-omron-x${200 + index}`,",
              "    meta: {",
              "      versionId: '1',",
              "      lastUpdated: timestamp",
              "    },",
              "    type: {",
              "      coding: [",
              "        {",
              "          system: 'http://snomed.info/sct',",
              "          code: '43770009',",
              "          display: `Blood pressure monitor ${suffix}`",
              "        }",
              "      ]",
              "    },",
              "    identifier: [",
              "      {",
              "        system: 'http://hl7.org/fhir/sid/ndc',",
              "        value: `SN-${String(9988776600 + index)}`",
              "      }",
              "    ]",
              "  };",
              "}",
              "",
              "function buildObservation(index, timestamp) {",
              "  const suffix = pad(index);",
              "  const systolic = 112 + (index % 18);",
              "  const diastolic = 70 + (index % 12);",
              "  return {",
              "    resourceType: 'Observation',",
              "    id: `bp-observation-device-${suffix}`,",
              "    meta: {",
              "      versionId: '1',",
              "      lastUpdated: timestamp,",
              "      profile: ['http://hl7.org/fhir/StructureDefinition/vitalsigns'],",
              "      tag: [",
              "        {",
              "          system: 'https://gaia-x.eu/trust-framework#',",
              "          code: 'sovereignty-policy',",
              "          display: `Data usage governed by patient consent ID: CONS-2026-${800 + index}`",
              "        }",
              "      ]",
              "    },",
              "    status: 'final',",
              "    category: [",
              "      {",
              "        coding: [",
              "          {",
              "            system: 'http://terminology.hl7.org/CodeSystem/observation-category',",
              "            code: 'vital-signs',",
              "            display: 'Vital Signs'",
              "          }",
              "        ]",
              "      }",
              "    ],",
              "    code: {",
              "      coding: [",
              "        {",
              "          system: 'http://loinc.org',",
              "          code: '85354-9',",
              "          display: 'Blood pressure panel with all children optional'",
              "        }",
              "      ],",
              "      text: 'Blood pressure systolic & diastolic'",
              "    },",
              "    subject: {",
              "      reference: `Patient/patient-gx-${suffix}`,",
              "      display: `Paciente Gaia ${suffix}`",
              "    },",
              "    encounter: {",
              "      reference: `Encounter/enc-home-monitoring-${suffix}`",
              "    },",
              "    effectiveDateTime: timestamp,",
              "    issued: new Date(new Date(timestamp).getTime() + 5000).toISOString(),",
              "    performer: [",
              "      {",
              "        reference: `Device/tensiometer-omron-x${200 + index}`,",
              "        display: `Omron X${200 + index} Smart Tensiómetro`",
              "      }",
              "    ],",
              "    bodySite: {",
              "      coding: [",
              "        {",
              "          system: 'http://snomed.info/sct',",
              "          code: '368209003',",
              "          display: 'Right arm'",
              "        }",
              "      ]",
              "    },",
              "    component: [",
              "      {",
              "        code: {",
              "          coding: [",
              "            {",
              "              system: 'http://loinc.org',",
              "              code: '8480-6',",
              "              display: 'Systolic blood pressure'",
              "            }",
              "          ]",
              "        },",
              "        valueQuantity: {",
              "          value: systolic,",
              "          unit: 'mmHg',",
              "          system: 'http://unitsofmeasure.org',",
              "          code: 'mm[Hg]'",
              "        }",
              "      },",
              "      {",
              "        code: {",
              "          coding: [",
              "            {",
              "              system: 'http://loinc.org',",
              "              code: '8462-4',",
              "              display: 'Diastolic blood pressure'",
              "            }",
              "          ]",
              "        },",
              "        valueQuantity: {",
              "          value: diastolic,",
              "          unit: 'mmHg',",
              "          system: 'http://unitsofmeasure.org',",
              "          code: 'mm[Hg]'",
              "        }",
              "      }",
              "    ],",
              "    device: {",
              "      reference: `Device/tensiometer-omron-x${200 + index}`,",
              "      type: {",
              "        coding: [",
              "          {",
              "            system: 'http://snomed.info/sct',",
              "            code: '43770009',",
              "            display: 'Blood pressure monitor'",
              "          }",
              "        ]",
              "      },",
              "      identifier: [",
              "        {",
              "          system: 'http://hl7.org/fhir/sid/ndc',",
              "          value: `SN-${String(9988776600 + index)}`",
              "        }",
              "      ]",
              "    }",
              "  };",
              "}",
              "",
              "const entries = [];",
              "const baseTime = new Date('2026-06-10T10:30:00+02:00');",
              "",
              "for (let index = 1; index <= 20; index++) {",
              "  const timestamp = buildTimestamp(baseTime, index);",
              "  entries.push({ resource: buildPatient(index, timestamp) });",
              "  entries.push({ resource: buildDevice(index, timestamp) });",
              "  entries.push({ resource: buildObservation(index, timestamp) });",
              "}",
              "",
              "pm.variables.set('fhirBundle', JSON.stringify({",
              "  resourceType: 'Bundle',",
              "  type: 'collection',",
              "  timestamp: new Date().toISOString(),",
              "  total: entries.length,",
              "  entry: entries",
              "}, null, 2));"
            ]
          }
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('POST responde con exito', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('La respuesta no esta vacia', function () {",
              "  pm.expect(pm.response.text()).to.have.length.greaterThan(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/fhir+json"
          },
          {
            "key": "Accept",
            "value": "application/fhir+json"
          },
          {
            "key": "X-Request-Id",
            "value": "{{requestId}}"
          }
        ],
        "url": "{{baseUrl}}/Bundle?x-request-id={{requestId}}",
        "body": {
          "mode": "raw",
          "raw": "{{fhirBundle}}"
        },
        "description": "Envía un Bundle FHIR con 20 pacientes, dispositivos y observaciones."
      },
      "response": []
    },
    {
      "name": "2. Recuperar pacientes",
      "description": "Verifica que la persistencia guardó los 20 primeros pacientes.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('GET pacientes responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Devuelve un Bundle FHIR', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resourceType).to.eql('Bundle');",
              "  pm.expect(body.entry || []).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/fhir+json"
          }
        ],
        "url": "{{baseUrl}}/Patient?_count=20",
        "description": "Recupera la lista de pacientes persistidos."
      },
      "response": []
    },
    {
      "name": "3. Recuperar observaciones",
      "description": "Verifica que las observaciones de presión arterial quedaron disponibles para el dashboard.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('GET observaciones responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Devuelve un Bundle FHIR', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resourceType).to.eql('Bundle');",
              "  pm.expect(body.entry || []).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/fhir+json"
          }
        ],
        "url": "{{baseUrl}}/Observation?_count=20&_sort=-date",
        "description": "Recupera las observaciones almacenadas para comprobar la persistencia."
      },
      "response": []
    },
    {
      "name": "4. Health provider",
      "description": "Comprueba que el provider está disponible y saludable.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Provider responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Provider esta UP', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{providerHealthUrl}}",
        "description": "Healthcheck del provider."
      },
      "response": []
    },
    {
      "name": "5. Health trust",
      "description": "Comprueba que el trust service está disponible y saludable.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Trust responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Trust esta UP', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{trustHealthUrl}}",
        "description": "Healthcheck del trust service."
      },
      "response": []
    },
    {
      "name": "6. Health consumer",
      "description": "Comprueba que el consumer está disponible y saludable.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Consumer responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Consumer esta UP', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{consumerHealthUrl}}",
        "description": "Healthcheck del consumer node."
      },
      "response": []
    },
    {
      "name": "7. Dashboard",
      "description": "Verifica que el dashboard responde en el puerto publicado.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Dashboard responde 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El dashboard devuelve contenido', function () {",
              "  pm.expect(pm.response.text()).to.have.length.greaterThan(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "text/html"
          }
        ],
        "url": "{{dashboardUrl}}",
        "description": "Comprueba la disponibilidad del frontend."
      },
      "response": []
    }
  ]
}
